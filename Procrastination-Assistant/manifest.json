{
  "manifest_version": 3,
  "name": "Procrastination Assistant",
  "version": "1.0",
  "description": "Helps students procrastinate efficiently",

  "icons": {
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.leetcode.com/*",
        "*://*.wikipedia.org/*",
        "*://*.geeksforgeeks.org/*"
      ],
      "js": ["content.js"]
    }
  ]
}